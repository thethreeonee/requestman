{
  "name": "requestman",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && npm run build:chrome && npm run build:firefox",
    "check:references": "node scripts/check-references.mjs",
    "build:chrome": "BUILD_TARGET=chrome vite build && node scripts/copy-static.mjs chrome",
    "build:firefox": "BUILD_TARGET=firefox vite build && node scripts/copy-static.mjs firefox",
    "package:firefox": "npm run build:firefox && node scripts/package-firefox.mjs"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@uiw/react-codemirror": "^4.23.12",
    "antd": "^5.27.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.6"
  }
}
