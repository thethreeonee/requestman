{
  "manifest_version": 3,
  "name": "Request Redirector DevTools",
  "version": "0.1.0",
  "description": "在开发者工具中配置请求重定向规则组。",
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "devtools_page": "devtools/devtools.html"
}
